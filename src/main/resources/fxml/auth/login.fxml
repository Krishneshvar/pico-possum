<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.picopossum.ui.auth.LoginController"
           prefWidth="1000.0" prefHeight="700.0" 
           style="-fx-background-color: linear-gradient(to bottom right, #f1f5f9, #cbd5e1);">
    
    <VBox alignment="CENTER" spacing="0" maxWidth="500">
        <!-- Main Card -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 30, 0, 0, 15);">
            <children>
                <!-- Header Section -->
                <VBox alignment="CENTER" spacing="15" style="-fx-background-color: #1e293b; -fx-background-radius: 24 24 0 0;">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40"/>
                    </padding>
                    <StackPane>
                        <Circle radius="40" fill="#3b82f6"/>
                        <FontIcon iconLiteral="bx-store-alt" iconSize="40" iconColor="white"/>
                    </StackPane>
                    <Label fx:id="titleLabel" text="Pico Possum" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Point of Sale Simplified" style="-fx-font-size: 14; -fx-text-fill: #94a3b8;"/>
                </VBox>

                <VBox spacing="24">
                    <padding>
                        <Insets top="40" right="50" bottom="50" left="50"/>
                    </padding>

                    <!-- Login Form -->
                    <VBox fx:id="loginForm" spacing="20" visible="false" managed="false">
                        <VBox spacing="8">
                            <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                <FontIcon iconLiteral="bx-user" iconSize="20" iconColor="#64748b"/>
                                <TextField fx:id="usernameField" promptText="Your username" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-padding: 8;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                <FontIcon iconLiteral="bx-lock-alt" iconSize="20" iconColor="#64748b"/>
                                <PasswordField fx:id="passwordField" promptText="Your password" HBox.hgrow="ALWAYS"
                                               style="-fx-background-color: transparent; -fx-padding: 8;"/>
                            </HBox>
                        </VBox>

                        <Button fx:id="loginButton" text="Sign In" maxWidth="Infinity"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 15;"/>
                    </VBox>

                    <!-- Setup/Register Form -->
                    <VBox fx:id="setupForm" spacing="22" visible="false" managed="false">
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="Create Owner Account" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                            <Label text="Since this is your first run, let's set up your admin access." style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
                        </VBox>
                        
                        <VBox spacing="8">
                            <Label text="Full Name" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                <FontIcon iconLiteral="bx-id-card" iconSize="20" iconColor="#64748b"/>
                                <TextField fx:id="setupNameField" promptText="e.g. John Doe" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-padding: 8;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Login Username" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                <FontIcon iconLiteral="bx-at" iconSize="20" iconColor="#64748b"/>
                                <TextField fx:id="setupUsernameField" promptText="Choose a username" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-padding: 8;"/>
                            </HBox>
                        </VBox>

                        <HBox spacing="15">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                <HBox alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                    <FontIcon iconLiteral="bx-lock-open-alt" iconSize="18" iconColor="#64748b"/>
                                    <PasswordField fx:id="setupPasswordField" promptText="••••••••" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: transparent; -fx-padding: 8;"/>
                                </HBox>
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Confirm" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                <HBox alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4 12;">
                                    <FontIcon iconLiteral="bx-check-double" iconSize="18" iconColor="#64748b"/>
                                    <PasswordField fx:id="setupConfirmPasswordField" promptText="••••••••" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: transparent; -fx-padding: 8;"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <Button fx:id="setupButton" text="Complete Setup →" maxWidth="Infinity"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 15;"/>
                    </VBox>
                </VBox>
            </children>
        </VBox>
        
        <Label text="Pico Possum v1.0.0 Beta" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-padding: 20 0 0 0;"/>
    </VBox>
</StackPane>
