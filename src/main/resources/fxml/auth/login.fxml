<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.net.URL?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.picopossum.ui.auth.LoginController"
           prefWidth="1100.0" prefHeight="750.0" 
           styleClass="auth-container">
    
    <stylesheets>
        <URL value="@../../styles/tokens.css" />
        <URL value="@../../styles/base.css" />
        <URL value="@../../styles/components.css" />
        <URL value="@../../styles/views/auth.css" />
    </stylesheets>

    <!-- Main Content Wrapper -->
    <HBox alignment="CENTER" maxWidth="1000" maxHeight="650" styleClass="auth-card-container">
        <!-- Brand Panel (Left) -->
        <VBox fx:id="brandPanel" styleClass="brand-panel" HBox.hgrow="ALWAYS" prefWidth="450" spacing="40" alignment="CENTER_LEFT">
            <VBox spacing="10">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="bx-store-alt" iconSize="48" styleClass="brand-logo-icon"/>
                    <VBox>
                        <Label text="PICO" styleClass="brand-title" style="-fx-font-size: 32; -fx-opacity: 0.7;"/>
                        <Label text="POSSUM" styleClass="brand-title">
                            <styleClass>
                                <String fx:value="brand-title-accent"/>
                            </styleClass>
                        </Label>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="25">
                <VBox spacing="8">
                    <Label text="Modern Retail Management" styleClass="brand-subtitle"/>
                    <Label text="Experience the power of a simplified Point of Sale system built for speed and efficiency." 
                           wrapText="true" styleClass="brand-feature-text" maxWidth="350"/>
                </VBox>

                <VBox spacing="15">
                    <HBox styleClass="brand-feature">
                        <FontIcon iconLiteral="bx-bolt-circle" styleClass="brand-feature-icon"/>
                        <Label text="Real-time Analytics" styleClass="brand-feature-text"/>
                    </HBox>
                    <HBox styleClass="brand-feature">
                        <FontIcon iconLiteral="bx-shield-quarter" styleClass="brand-feature-icon"/>
                        <Label text="Secure Data Management" styleClass="brand-feature-text"/>
                    </HBox>
                    <HBox styleClass="brand-feature">
                        <FontIcon iconLiteral="bx-layout" styleClass="brand-feature-icon"/>
                        <Label text="Intuitive User Interface" styleClass="brand-feature-text"/>
                    </HBox>
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Pico Possum. All rights reserved." styleClass="footer-text" style="-fx-text-fill: white; -fx-opacity: 0.5;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="v1.0" styleClass="footer-text" style="-fx-text-fill: white; -fx-opacity: 0.3;"/>
            </HBox>
        </VBox>

        <!-- Form Panel (Right) -->
        <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" prefWidth="550" spacing="35" alignment="CENTER_LEFT">
            <VBox spacing="8" styleClass="form-header-container">
                <Label fx:id="formTitle" text="Welcome Back" styleClass="form-title"/>
                <Label fx:id="formSubtitle" text="Please enter your details to sign in." styleClass="form-subtitle"/>
            </VBox>

            <!-- Forms Container -->
            <StackPane alignment="TOP_LEFT">
                <!-- Login Form -->
                <VBox fx:id="loginForm" spacing="25" visible="true">
                    <VBox spacing="20">
                        <VBox styleClass="field-group">
                            <Label text="USERNAME" styleClass="field-label"/>
                            <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field"/>
                        </VBox>

                        <VBox styleClass="field-group">
                            <Label text="PASSWORD" styleClass="field-label"/>
                            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="password-field"/>
                        </VBox>
                    </VBox>

                    <Button fx:id="loginButton" text="Sign in" maxWidth="Infinity" styleClass="auth-submit-button"/>
                </VBox>

                <!-- Setup/Register Form (Initial State) -->
                <VBox fx:id="setupForm" spacing="25" visible="false" managed="false">
                    <VBox spacing="15">
                        <VBox styleClass="field-group">
                            <Label text="BUSINESS OWNER NAME" styleClass="field-label"/>
                            <TextField fx:id="setupNameField" promptText="e.g. John Doe" styleClass="text-field"/>
                        </VBox>

                        <VBox styleClass="field-group">
                            <Label text="ADMIN USERNAME" styleClass="field-label"/>
                            <TextField fx:id="setupUsernameField" promptText="Choose a username" styleClass="text-field"/>
                        </VBox>

                        <HBox spacing="15">
                            <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                                <Label text="PASSWORD" styleClass="field-label"/>
                                <PasswordField fx:id="setupPasswordField" promptText="••••••••" styleClass="password-field"/>
                            </VBox>
                            <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                                <Label text="CONFIRM" styleClass="field-label"/>
                                <PasswordField fx:id="setupConfirmPasswordField" promptText="••••••••" styleClass="password-field"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <Button fx:id="setupButton" text="Initialize System" maxWidth="Infinity" styleClass="auth-submit-button"/>
                </VBox>
            </StackPane>

            <VBox alignment="CENTER" spacing="10">
                <Separator/>
            </VBox>
        </VBox>
    </HBox>

    <!-- Overlay Decorations (Optional) -->
    <Region style="-fx-background-color: -color-primary; -fx-opacity: 0.03; -fx-shape: 'M 0 0 L 100 0 L 100 100 Z';" 
            maxWidth="300" maxHeight="300" StackPane.alignment="TOP_RIGHT"/>
    <Region style="-fx-background-color: -color-primary; -fx-opacity: 0.03; -fx-shape: 'M 0 100 L 100 100 L 0 0 Z';" 
            maxWidth="200" maxHeight="200" StackPane.alignment="BOTTOM_LEFT"/>
</StackPane>
