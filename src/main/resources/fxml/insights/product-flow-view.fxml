<?xml version="1.0" encoding="UTF-8"?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.net.URL?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import com.picopossum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="root"
      fx:controller="com.picopossum.ui.insights.ProductFlowController"
      styleClass="workspace-view">
    
    <stylesheets>
        <URL value="@../../styles/inventory.css"/>
        <URL value="@../../styles/views/pos.css"/>
    </stylesheets>
    
    <fx:define>
        <HBox fx:id="searchDock" alignment="CENTER_LEFT" spacing="8">
            <TextField fx:id="searchField" promptText="Search products..." HBox.hgrow="ALWAYS" styleClass="search-field-pos" prefWidth="300">
                <tooltip>
                    <Tooltip text="Start typing to select item"/>
                </tooltip>
            </TextField>
        </HBox>
    </fx:define>
    
    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Product Flow Analysis" styleClass="view-title"/>
            <Label text="Gain insights into stock movement, sales velocity, and inventory turnover." styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Refresh" onAction="#handleRefresh" styleClass="action-button" accessibleText="Refresh product flow data">
                <graphic><FontIcon iconLiteral="bx-sync" iconSize="16"/></graphic>
                <tooltip>
                    <Tooltip text="Refresh the product flow data"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>
    
    <!-- Summary Stats Bar -->
    <HBox fx:id="summaryBar" spacing="16" style="-fx-padding: 0 0 16 0;">
        <VBox styleClass="kpi-card-mini" HBox.hgrow="ALWAYS">
            <Label text="Net Movement" styleClass="kpi-label-mini"/>
            <Label fx:id="netMovementLabel" text="0" styleClass="kpi-value-mini"/>
        </VBox>
        <VBox styleClass="kpi-card-mini" HBox.hgrow="ALWAYS">
            <Label text="Total Sold" styleClass="kpi-label-mini"/>
            <Label fx:id="totalSoldLabel" text="0" styleClass="kpi-value-mini"/>
        </VBox>
        <VBox styleClass="kpi-card-mini" HBox.hgrow="ALWAYS">
            <Label text="Total Returned" styleClass="kpi-label-mini"/>
            <Label fx:id="totalReturnedLabel" text="0" styleClass="kpi-value-mini"/>
        </VBox>
        <VBox styleClass="kpi-card-mini" HBox.hgrow="ALWAYS">
            <Label text="Total Gained" styleClass="kpi-label-mini"/>
            <Label fx:id="totalGainedLabel" text="0" styleClass="kpi-value-mini"/>
        </VBox>
        <VBox styleClass="kpi-card-mini" HBox.hgrow="ALWAYS">
            <Label text="Total Lost" styleClass="kpi-label-mini"/>
            <Label fx:id="totalLostLabel" text="0" styleClass="kpi-value-mini"/>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="card">
        <FilterBar fx:id="filterBar"/>
        


        <DataTableView fx:id="flowTable" VBox.vgrow="ALWAYS"/>
        
        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
