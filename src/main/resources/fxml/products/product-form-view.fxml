<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.SingleSelectFilter?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possum.ui.products.ProductFormController"
            fitToWidth="true"
            stylesheets="@../../styles/inventory.css"
            styleClass="workspace-view, form-container">

    <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 30 40;">
        <VBox spacing="25" maxWidth="1200" alignment="TOP_LEFT">

        <HBox styleClass="view-header" alignment="CENTER_LEFT">
            <Button onAction="#handleCancel" styleClass="back-link" accessibleText="Go back to products list" accessibleRole="BUTTON">
                <graphic><FontIcon iconLiteral="bx-arrow-back" iconSize="16"/></graphic>
                <tooltip>
                    <Tooltip text="Return without saving (Esc)"/>
                </tooltip>
            </Button>
            <Label fx:id="titleLabel" text="Add Product" styleClass="view-title" accessibleRole="TEXT"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Cancel" onAction="#handleCancel" styleClass="action-button" cancelButton="true" accessibleText="Cancel product creation" accessibleRole="BUTTON">
                <tooltip>
                    <Tooltip text="Return without saving (Esc)"/>
                </tooltip>
            </Button>
            <Button fx:id="saveButton" text="Save Product" onAction="#handleSave" styleClass="action-button, primary-button" defaultButton="true" accessibleText="Save the product" accessibleRole="BUTTON">
                <tooltip>
                    <Tooltip text="Save product (Enter)"/>
                </tooltip>
            </Button>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <!-- Left Column: Product Details -->
            <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="800">
                <VBox styleClass="card" spacing="20">
                    <VBox spacing="4">
                        <Label text="General Information" styleClass="card-title" style="-fx-font-size: 18px;"/>
                        <Label text="Core details defining the product." style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                        <Separator style="-fx-padding: 8 0;"/>
                    </VBox>

                    <VBox styleClass="form-group" spacing="8">
                        <HBox spacing="4" alignment="BOTTOM_LEFT">
                            <Label text="Product Name" styleClass="form-label" labelFor="$nameField" style="-fx-font-weight: 600;"/>
                            <Label text="*" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                        </HBox>
                        <TextField fx:id="nameField" promptText="e.g., Artisan Coffee Beans" styleClass="text-field" accessibleText="Product name input"/>
                    </VBox>

                    <VBox styleClass="form-group" spacing="8">
                        <Label text="Description (Optional)" styleClass="form-label" labelFor="$descriptionField" style="-fx-font-weight: 600;"/>
                        <TextArea fx:id="descriptionField" promptText="Provide a brief description of the product..." prefRowCount="3" styleClass="text-area" accessibleText="Product description input"/>
                    </VBox>

                    <HBox spacing="15">
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="SKU" styleClass="form-label" labelFor="$skuField" style="-fx-font-weight: 600;"/>
                            <TextField fx:id="skuField" promptText="Stock Keeping Unit" styleClass="text-field"/>
                        </VBox>
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Barcode" styleClass="form-label" labelFor="$barcodeField" style="-fx-font-weight: 600;"/>
                            <TextField fx:id="barcodeField" promptText="Optional barcode" styleClass="text-field"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="card" spacing="20">
                    <VBox spacing="4">
                        <Label text="Pricing &amp; Inventory" styleClass="card-title" style="-fx-font-size: 18px;"/>
                        <Label text="Manage pricing and stock levels." style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                        <Separator style="-fx-padding: 8 0;"/>
                    </VBox>

                    <HBox spacing="15">
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <HBox spacing="4" alignment="BOTTOM_LEFT">
                                <Label text="Selling Price" styleClass="form-label" labelFor="$priceField" style="-fx-font-weight: 600;"/>
                                <Label text="*" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                            </HBox>
                            <TextField fx:id="priceField" promptText="0.00" styleClass="text-field"/>
                        </VBox>
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <HBox spacing="4" alignment="BOTTOM_LEFT">
                                <Label text="Cost Price" styleClass="form-label" labelFor="$costPriceField" style="-fx-font-weight: 600;"/>
                                <Label text="*" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                            </HBox>
                            <TextField fx:id="costPriceField" promptText="0.00" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="15">
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Stock Alert Level" styleClass="form-label" labelFor="$stockAlertField" style="-fx-font-weight: 600;"/>
                            <TextField fx:id="stockAlertField" promptText="10" styleClass="text-field"/>
                        </VBox>
                        <VBox styleClass="form-group" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Initial Stock" styleClass="form-label" labelFor="$stockField" style="-fx-font-weight: 600;"/>
                            <TextField fx:id="stockField" promptText="0" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <VBox fx:id="adjustmentReasonBox" styleClass="form-group" spacing="8" visible="false" managed="false">
                        <Label text="Adjustment Reason" styleClass="form-label" style="-fx-font-weight: 600;"/>
                        <ComboBox fx:id="adjustmentReasonCombo" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Right Column: Settings -->
            <VBox spacing="20" minWidth="300" maxWidth="400">
                <VBox styleClass="card" spacing="20">
                    <VBox spacing="4">
                        <Label text="Organization" styleClass="card-title" style="-fx-font-size: 18px;"/>
                        <Label text="Categorize your product." style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                        <Separator style="-fx-padding: 8 0;"/>
                    </VBox>

                    <VBox styleClass="form-group" spacing="8">
                        <Label text="Category" styleClass="form-label" labelFor="$categoryFilter" style="-fx-font-weight: 600;"/>
                        <SingleSelectFilter fx:id="categoryFilter" title="Select Category..." maxWidth="Infinity" styleClass="single-select-filter" accessibleText="Product category selection"/>
                    </VBox>

                    <VBox styleClass="form-group" spacing="8">
                        <Label text="Status" styleClass="form-label" labelFor="$statusCombo" style="-fx-font-weight: 600;"/>
                        <ComboBox fx:id="statusCombo" promptText="Select..." maxWidth="Infinity" styleClass="combo-box" accessibleText="Product status selection"/>
                    </VBox>


                </VBox>
            </VBox>

        </HBox>
        </VBox>
    </VBox>
</ScrollPane>
